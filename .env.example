# =============================================================================
# ResolveMeQ Environment Configuration Template
# =============================================================================
# Copy this file to .env and update with your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# Django Settings
# -----------------------------------------------------------------------------
SECRET_KEY=your-secret-key-here-generate-a-new-one
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=https://app.resolvemeq.com

# Google Sign-In — Web client ID from Google Cloud Console (APIs & Services → Credentials).
# Must match the frontend VITE_GOOGLE_CLIENT_ID. Authorized JavaScript origins: your app URL(s).
GOOGLE_OAUTH_CLIENT_ID=

# -----------------------------------------------------------------------------
# PostgreSQL Database Configuration
# -----------------------------------------------------------------------------
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=your-database-host.com
DB_PORT=5432

# -----------------------------------------------------------------------------
# Redis & Celery Configuration
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Slack Integration
# -----------------------------------------------------------------------------
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_REDIRECT_URI=https://api.resolvemeq.com/integrations/slack/oauth/callback
# Optional: Slack channel ID (e.g. C01234ABCD) to post escalated tickets for support visibility
SLACK_ESCALATION_CHANNEL=

# -----------------------------------------------------------------------------
# Email Configuration (SMTP)
# -----------------------------------------------------------------------------
# Deliverability: use SMTP from your *own* domain (SendGrid, SES, Mailgun, or
# Google Workspace with SPF+DKIM). Personal Gmail + random From address often hits spam.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
# "Name <email@yourdomain.com>" — domain must match SPF/DKIM/DMARC DNS records.
DEFAULT_FROM_EMAIL=ResolveMeQ <noreply@yourdomain.com>
# Shown in password-reset template and Reply-To on transactional mail (optional).
SUPPORT_EMAIL=support@yourdomain.com
# Comma-separated inboxes for "Contact support" submissions from the app (Billing). Falls back to SUPPORT_EMAIL if empty.
# SUPPORT_CONTACT_NOTIFY_EMAILS=ops@yourdomain.com,founder@yourdomain.com
APP_NAME=ResolveMeQ
# true=queue via Celery (needs worker). false=send in-process. Unset: sync under runserver, Celery otherwise.
# EMAIL_USE_CELERY=true

# Celery Beat: daily digest to users who enable it in Settings (requires celery beat + worker + SMTP).
# ENABLE_DIGEST_EMAIL_SCHEDULE=true
# DIGEST_EMAIL_HOUR_UTC=8

# -----------------------------------------------------------------------------
# AI Agent Service
# -----------------------------------------------------------------------------
AI_AGENT_URL=https://agent.resolvemeq.com/tickets/analyze/

# -----------------------------------------------------------------------------
# Monitoring & Error Tracking (Sentry)
# -----------------------------------------------------------------------------
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
ENVIRONMENT=production
APP_VERSION=2.0.0

# -----------------------------------------------------------------------------
# Agent Rate Limiting & Safety
# -----------------------------------------------------------------------------
MAX_AUTONOMOUS_ACTIONS_PER_DAY=500
MAX_AUTONOMOUS_ACTIONS_PER_HOUR=100
